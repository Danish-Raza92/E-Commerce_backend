# =============================================
# DANII.STORE BACKEND — Environment Variables
# =============================================
# Railway pe yeh sab Settings > Variables mein add karo
# LOCAL ke liye: cp .env.example .env

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/danii-store?retryWrites=true&w=majority

# JWT Secret (generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=your_super_secret_jwt_key_change_this

# Server
PORT=5000
NODE_ENV=production

# Your Vercel frontend URL (CORS ke liye zaroori)
# Example: https://danii-store.vercel.app
FRONTEND_URL=https://YOUR-PROJECT-NAME.vercel.app
